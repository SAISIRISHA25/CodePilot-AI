# OpenAI configuration (API Key and optional settings)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REQUEST_TIMEOUT_SECONDS=60

# LangSmith tracing configuration (optional)
LANGSMITH_TRACING_ENABLED=true
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=codepilot-ai-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Core application config
APP_NAME=CodePilot AI
APP_ENV=development
APP_DEBUG=true

# Databases and directories
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=codepilot_documents
SQLITE_DATABASE_PATH=./data/codepilot.db
SQLITE_ECHO=false

# Logging configurations
LOG_LEVEL=INFO
LOG_JSON_FORMAT=false
